# Copia este archivo como .env y llena los valores reales
# NUNCA subas el .env real a git

# ── Base de datos (Neon PostgreSQL) ───────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── API ───────────────────────────────────────────────────────────
# En local: dejar vacío o poner * para permitir cualquier origen
# En servidor: poner https://tudominio.com
CORS_ORIGINS=*

# ── Frontend ──────────────────────────────────────────────────────
# En local: http://localhost/api
# En servidor: https://tudominio.com/api
NEXT_PUBLIC_API_URL=http://localhost/api/v1

# ── Scrapers ──────────────────────────────────────────────────────
# Activar modo headless de Chromium (obligatorio en Docker)
CI=true
MAX_PAGINAS=2
